# ============================================
# Django Core Settings
# ============================================
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-min-50-characters
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# StreameX API Configuration
# ============================================
STREAMEX_API_BASE_URL=http://localhost:5000/api
API_TIMEOUT=30

# ============================================
# Optional: API Response Caching
# ============================================
ENABLE_API_CACHE=True
API_CACHE_TTL=3600

# ============================================
# Production Security Settings (Uncomment for production)
# ============================================
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_BROWSER_XSS_FILTER=True
# SECURE_CONTENT_TYPE_NOSNIFF=True
