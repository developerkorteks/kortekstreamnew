{
  "name": "streaming-site",
  "version": "1.0.0",
  "description": "Streaming site with Tailwind CSS",
  "scripts": {
    "build:css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --minify",
    "watch:css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch",
    "dev": "npm run watch:css",
    "pm2:start": "./scripts/start_pm2.sh",
    "pm2:stop": "./scripts/stop_pm2.sh",
    "pm2:restart": "./node_modules/.bin/pm2 restart kortekstream",
    "pm2:logs": "./node_modules/.bin/pm2 logs kortekstream",
    "pm2:status": "./node_modules/.bin/pm2 status",
    "pm2:monit": "./node_modules/.bin/pm2 monit"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1"
  },
  "dependencies": {
    "pm2": "^6.0.14"
  }
}
